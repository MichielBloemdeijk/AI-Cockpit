# Copy this file to .env and fill in your values
# NEVER commit .env to git

# OpenRouter API key (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Auth: bcrypt-hashed password. Generate with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
AUTH_PASSWORD_HASH=$2b$12$placeholder_replace_me

# Session secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=change-me-to-a-random-secret

# LLM Council models (comma-separated OpenRouter model IDs)
COUNCIL_MODELS=anthropic/claude-sonnet-4-5,google/gemini-pro-1.5,openai/gpt-4o

# Synthesizer model (picks up council responses and unifies them)
SYNTHESIZER_MODEL=anthropic/claude-sonnet-4-5

# Allowed project directories for file browser (comma-separated absolute paths)
ALLOWED_DIRS=C:\Users\Sander\Documents\Repos

# ntfy.sh topic for push notifications (optional)
NTFY_TOPIC=

# Tailscale hostname or IP (optional, used for remote dev-host allowance and CORS)
TAILSCALE_HOST=
